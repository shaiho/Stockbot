TELEGRAM_BOT_TOKEN=your_bot_token_here
FINNHUB_API_KEY=your_finnhub_key_here
# Supabase Postgres (recommended for production). When set, SQLite is ignored.
# Windows/IPv4: use Session pooler (port 5432), NOT direct db.*.supabase.co (IPv6-only).
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
# Local SQLite fallback when DATABASE_URL is empty
DATABASE_PATH=data/stockbot.db
TIMEZONE=Asia/Jerusalem
# Comma-separated Telegram user IDs allowed to run /admin (get yours from @userinfobot)
ADMIN_TELEGRAM_IDS=123456789
